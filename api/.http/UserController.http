@baseUrl = http://localhost:8080

######################################################################
# SCENARIO — Récupérer les infos du compte connecté
######################################################################

### Login (obtenir un token)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "donor@example.com",
  "password": "Toto123!"
}

> {%
  client.global.set("accessToken", response.body.accessToken);
%}

### GET /api/user/me — infos du compte courant
GET {{baseUrl}}/api/user/me
Authorization: Bearer {{accessToken}}

######################################################################
# SCENARIO — Créer / mettre à jour le profil d'une association (Step 3 du signup)
######################################################################

### 1. S'enregistrer comme association (sans profil) → 204 (email de vérification envoyé)
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "email": "asso@example.com",
  "password": "Toto123!",
  "role": "ASSOCIATION"
}

### 1b. Vérifier l'email → capture accessToken (ou utiliser /api/auth/login si déjà vérifié)
POST {{baseUrl}}/api/auth/verify-email
Content-Type: application/json

{
  "token": "<verification_token_from_email>"
}

> {%
  client.global.set("accessToken", response.body.accessToken);
%}

### 2. Soumettre le profil association (Step 3) → 204
PATCH {{baseUrl}}/api/user/me/association-profile
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "nom": "Médecins Sans Frontières",
  "siren": "775707227",
  "ville": "Paris",
  "codePostal": "75011",
  "contact": "contact@msf.fr",
  "description": "Organisation humanitaire internationale"
}



######################################################################
# SCENARIO — Définir un mot de passe après signup Google / Magic Link
######################################################################

### 1. Login pour obtenir un token (compte sans mot de passe initialement)
#    Remplacer par magic-link/verify ou signup/google si besoin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "donor@example.com",
  "password": "ancienMotDePasse123"
}

> {%
  client.global.set("accessToken", response.body.accessToken);
%}

### 2. Définir / mettre à jour le mot de passe → 204
PATCH {{baseUrl}}/api/user/me/password
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "password": "nouveauMotDePasse123",
  "confirmPassword": "nouveauMotDePasse123"
}

### 3. Vérifier que le nouveau mot de passe fonctionne
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "donor@example.com",
  "password": "nouveauMotDePasse123"
}

> {%
  client.global.set("accessToken", response.body.accessToken);
  client.global.set("refreshToken", response.body.refreshToken);
%}
